rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== USERS COLLECTION ====================
    match /users/{userId} {
      // أي حد يقدر يقرأ بيانات المستخدمين (للبروفايلات العامة)
      allow read: if true;
      
      // المستخدم بس اللي يقدر يعدل أو يحذف حسابه
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // منع أي حد من إنشاء حساب باسم مستخدم تاني
      allow create: if request.auth != null && request.auth.uid == userId;
    }
    
    // ==================== POSTS COLLECTION ====================
    match /posts/{postId} {
      // أي حد يقدر يشوف البوستات (حتى الضيوف)
      allow read: if true;
      
      // المستخدم يقدر ينشر بوستات باسمه هو فقط
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;
      
      // صاحب البوست بس اللي يقدر يعدل أو يحذف
      allow update, delete: if request.auth != null 
                           && resource.data.userId == request.auth.uid;
    }
    
    // ==================== COMMENTS COLLECTION ====================
    match /comments/{commentId} {
      // أي حد يقدر يشوف التعليقات
      allow read: if true;
      
      // المستخدم يقدر يضيف تعليقات باسمه
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;
      
      // صاحب التعليق بس اللي يقدر يعدل أو يحذف
      allow update, delete: if request.auth != null 
                           && resource.data.userId == request.auth.uid;
    }
    
    // ==================== CHATS COLLECTION ====================
    match /chats/{chatId} {
      // المشاركين في المحادثة بس اللي يقدر يشوفوها
      allow read: if request.auth != null 
                  && request.auth.uid in resource.data.participants;
      
      // إنشاء محادثة جديدة
      allow create: if request.auth != null 
                    && request.auth.uid in request.resource.data.participants;
      
      // المشاركين بس اللي يقدر يعدلوا
      allow update: if request.auth != null 
                    && request.auth.uid in resource.data.participants;
      
      // منع الحذف
      allow delete: if false;
    }
    
    // ==================== MESSAGES COLLECTION ====================
    match /chats/{chatId}/messages/{messageId} {
      // المشاركين في المحادثة بس اللي يقدر يشوفوا الرسائل
      allow read: if request.auth != null 
                  && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      
      // المشاركين بس اللي يقدر يبعتوا رسائل
      allow create: if request.auth != null 
                    && request.auth.uid == request.resource.data.senderId
                    && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      
      // منع التعديل أو الحذف
      allow update, delete: if false;
    }
    
    // ==================== NOTIFICATIONS COLLECTION ====================
    match /notifications/{notificationId} {
      // المستخدم يقدر يشوف إشعاراته هو فقط
      allow read: if request.auth != null 
                  && request.auth.uid == resource.data.userId;
      
      // النظام فقط اللي يقدر ينشئ إشعارات
      allow create: if request.auth != null;
      
      // المستخدم يقدر يحذف إشعاراته
      allow delete: if request.auth != null 
                    && request.auth.uid == resource.data.userId;
      
      // منع التعديل على الإشعارات
      allow update: if false;
    }
    
    // ==================== REPORTS COLLECTION ====================
    match /reports/{reportId} {
      // المستخدمين اللي عملوا البلاغ بس اللي يقدر يشوفوه
      allow read: if request.auth != null 
                  && request.auth.uid == resource.data.reporterId;
      
      // أي مستخدم مسجل دخول يقدر يعمل بلاغ
      allow create: if request.auth != null 
                    && request.resource.data.reporterId == request.auth.uid;
      
      // منع التعديل أو الحذف
      allow update, delete: if false;
    }
    
    // ==================== STORIES COLLECTION ====================
    match /stories/{storyId} {
      // أي حد يقدر يشوف القصص
      allow read: if true;
      
      // المستخدم يقدر ينشر قصص باسمه
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;
      
      // صاحب القصة بس اللي يقدر يحذفها
      allow delete: if request.auth != null 
                    && resource.data.userId == request.auth.uid;
      
      // منع تعديل القصص
      allow update: if false;
    }
    
    // ==================== GROUPS COLLECTION ====================
    match /groups/{groupId} {
      // أي حد يقدر يشوف المجموعات
      allow read: if true;
      
      // أي مستخدم مسجل دخول يقدر ينشئ مجموعة
      allow create: if request.auth != null 
                    && request.resource.data.creatorId == request.auth.uid;
      
      // منشئ المجموعة بس اللي يقدر يعدل
      allow update: if request.auth != null 
                    && resource.data.creatorId == request.auth.uid;
      
      // منع الحذف
      allow delete: if false;
    }
    
    // ==================== RATINGS COLLECTION ====================
    match /ratings/{ratingId} {
      // أي حد يقدر يشوف التقييمات
      allow read: if true;
      
      // المستخدم يقدر يضيف تقييم
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;
      
      // منع التعديل أو الحذف
      allow update, delete: if false;
    }
    
  }
}